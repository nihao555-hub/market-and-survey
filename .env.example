# ════════════════════════════════════════════════════════════════════
# 第一环节·选品/市场调研 Agent — 环境变量示例
# 复制为根目录 .env 后填值：  cp .env.example .env
# （modules/llm.py、backend/auth.py 等都从仓库根目录的 .env 读取）
# ════════════════════════════════════════════════════════════════════

# ── LLM：DeepSeek（OpenAI 兼容协议）────────────────────────────────
# 必填。无 Key 时模块仍可 import、纯函数/单测可跑，但 Agent 实际对话会 401。
DEEPSEEK_API_KEY=
# 可选，默认 https://api.deepseek.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 可选，模型名（默认即官方现行名，一般无需改）
# Flash=编排/工具调用；Pro=最终决策。旧别名 deepseek-chat/deepseek-reasoner 将于 2026-07-24 下线。
DEEPSEEK_MODEL_FLASH=deepseek-v4-flash
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

# ── 后端鉴权 / 多租户 ──────────────────────────────────────────────
# "key:tenant,key2:tenant2" 形式，按 X-API-Key 请求头映射到租户。
BACKEND_API_KEYS=dev-key-local:dev_tenant
# 0=dev 放行（无 key 归 dev_tenant）；生产务必设为 1 强制校验。
BACKEND_AUTH_REQUIRED=0

# ── 队列 / 事件总线（Redis）────────────────────────────────────────
# pub/sub + dramatiq 任务队列 + SSE 重放。默认本机 6379。
REDIS_URL=redis://127.0.0.1:6379/0
# 1=用 dramatiq worker 跑任务；0=进程内直接跑（dev 默认）。
USE_DRAMATIQ_WORKER=0

# ── TikHub API（TikTok Shop + 社媒趋势）─────────────────────────────
# 必填（生产环境）。提供 TikTok Shop 实时商品/品类/热销榜 + 社媒热搜数据。
# 注册 https://tikhub.io 获取 API Key。
TIKHUB_API_KEY=
# 可选，默认 https://api.tikhub.io
TIKHUB_BASE_URL=https://api.tikhub.io

# ── ScraperAPI（全球电商平台爬取代理）────────────────────────────────
# 用于爬取被反爬保护的电商平台（Walmart/eBay/Etsy/Shopee/Coupang/Ozon 等）。
# 免费 1000 credits/月，注册 https://www.scraperapi.com 获取 API Key。
# 不填则这些平台的数据不可用，仅走 TikHub + 本地代理。
SCRAPERAPI_KEY=

# ── 采集代理（可选，真实抓取美区平台时需要）──────────────────────
# 美国出口 IP（xray/住宅代理等）。默认走本机 127.0.0.1:10808。
US_PROXY=http://127.0.0.1:10808

# ── 可选付费数据源（不填则走免费抓取/估算回退）──────────────────
# Keepa（Amazon 历史价格/BSR）
KEEPA_EMAIL=
KEEPA_PASSWORD=
# DataForSEO（关键词/SERP）
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# RapidAPI（Amazon 数据 API）
RAPIDAPI_KEY=
RAPIDAPI_AMAZON_HOST=

# ── 前端 ───────────────────────────────────────────────────────────
# 以下变量写在 frontend/.env.local（而非本文件）：
# 后端地址（默认 http://127.0.0.1:8001）
# NEXT_PUBLIC_BACKEND_BASE=http://127.0.0.1:8001
# 后端开启鉴权（BACKEND_AUTH_REQUIRED=1）时，前端 SSE 用的 key（dev 留空）
# NEXT_PUBLIC_BACKEND_API_KEY=dev-key-local
